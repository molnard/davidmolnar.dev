---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';
import type { CollectionEntry } from 'astro:content';

const t = useTranslations('en');

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter((p: CollectionEntry<'projects'>) => p.data.lang === 'en' && !p.data.draft)
  .sort((a: CollectionEntry<'projects'>, b: CollectionEntry<'projects'>) =>
    (b.data.year ?? 0) - (a.data.year ?? 0)
  );

const competencies = ['bitcoin', 'software', 'firmware', 'smarthome', '3d-printing'] as const;
const competencyLabels: Record<string, string> = {
  bitcoin: 'Bitcoin',
  software: 'Software',
  firmware: 'Firmware',
  smarthome: 'Smart home',
  '3d-printing': '3D printing',
};
---

<BaseLayout
  title="Projects — David Molnar"
  description="A collection of projects across Bitcoin privacy, software engineering, firmware, smart home, and 3D printing."
  altHref="/hu/projects/"
>
  <section class="bg-paper min-h-screen">
    <div class="max-w-6xl mx-auto px-6 md:px-8 pt-16 pb-24">
      <h1 class="font-display font-bold text-4xl md:text-5xl tracking-tight text-ink mb-12">
        {t('projects.title')}
      </h1>

      <!-- Filter bar -->
      <div class="mb-4">
        <div class="flex flex-wrap gap-2" id="filter-btns">
          <button class="filter-btn" data-filter="all" data-active="true">
            {t('projects.filter.all')}
          </button>
          {competencies.map(c => (
            <button class="filter-btn" data-filter={c} data-active="false">
              {competencyLabels[c]}
            </button>
          ))}
        </div>
      </div>

      <!-- Sort bar -->
      <div class="flex items-center gap-2 mb-10">
        <span class="text-xs text-muted">Sort:</span>
        <div class="flex gap-1" id="sort-btns">
          <button class="sort-btn" data-sort="newest" data-active="true">{t('projects.sort.newest')}</button>
          <button class="sort-btn" data-sort="oldest" data-active="false">{t('projects.sort.oldest')}</button>
          <button class="sort-btn" data-sort="az" data-active="false">{t('projects.sort.az')}</button>
        </div>
      </div>

      <!-- Grid -->
      <div id="projects-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {projects.map((p: CollectionEntry<'projects'>) => (
          <div
            class="project-card"
            data-competencies={p.data.competencies.join(' ')}
            data-year={p.data.year ?? 0}
            data-title={p.data.title.toLowerCase()}
          >
            <a
              href={`/projects/${p.data.projectId}/`}
              class="group flex flex-col rounded-2xl overflow-hidden border border-ink/10 bg-paper hover:border-forest/40 transition-colors h-full"
            >
              {(p.data.cardImage ?? p.data.image) ? (
                <div class="aspect-[16/9] overflow-hidden bg-[#0F1A14]">
                  <img
                    src={p.data.cardImage ?? p.data.image}
                    alt={p.data.title}
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                  />
                </div>
              ) : (
                <div class="aspect-[16/9] bg-gradient-to-br from-[#1F352B] to-[#0F1A14]"></div>
              )}
              <div class="flex flex-col flex-1 p-5">
                <div class="flex items-start justify-between gap-3 mb-2">
                  <h2 class="font-display font-semibold text-lg text-ink group-hover:text-forest transition-colors">{p.data.title}</h2>
                  {p.data.year && <span class="font-mono text-[11px] text-muted shrink-0 mt-1">{p.data.year}</span>}
                </div>
                <p class="text-sm text-muted leading-relaxed mb-4 flex-1">{p.data.shortDesc}</p>
                <div class="flex flex-wrap gap-1.5">
                  {p.data.tags.slice(0, 4).map((tag: string) => (
                    <span class="font-mono text-[10px] uppercase tracking-wide px-2 py-0.5 rounded-full bg-forest/10 text-forest-dark">{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>

      <p id="empty-msg" class="hidden text-sm text-muted mt-10">{t('projects.empty')}</p>
    </div>
  </section>
</BaseLayout>

<style>
  .filter-btn {
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    border: 1.5px solid rgba(26,24,22,0.15);
    color: rgba(26,24,22,0.45);
    background: transparent;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
    white-space: nowrap;
    line-height: 1.4;
  }
  .filter-btn:hover {
    border-color: rgba(26,24,22,0.4);
    color: #1A1816;
  }
  .filter-btn[data-active="true"] {
    background: #1A1816;
    border-color: #1A1816;
    color: #F8F5F0;
  }

  .sort-btn {
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.375rem 0.875rem;
    border-radius: 0.5rem;
    border: none;
    color: rgba(26,24,22,0.4);
    background: transparent;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .sort-btn:hover {
    background: rgba(26,24,22,0.06);
    color: #1A1816;
  }
  .sort-btn[data-active="true"] {
    background: rgba(26,24,22,0.08);
    color: #1A1816;
    font-weight: 600;
  }
</style>

<script is:inline>
  (() => {
    const cards = Array.from(document.querySelectorAll('.project-card'));
    const filterBtns = Array.from(document.querySelectorAll('.filter-btn'));
    const sortBtns = Array.from(document.querySelectorAll('.sort-btn'));
    const grid = document.getElementById('projects-grid');
    const emptyMsg = document.getElementById('empty-msg');

    let activeFilters = new Set(); // empty = show all
    let activeSort = 'newest';

    function render() {
      // Sort
      const sorted = [...cards].sort((a, b) => {
        if (activeSort === 'newest') return Number(b.dataset.year) - Number(a.dataset.year);
        if (activeSort === 'oldest') return Number(a.dataset.year) - Number(b.dataset.year);
        if (activeSort === 'az') return a.dataset.title.localeCompare(b.dataset.title);
        return 0;
      });
      sorted.forEach(c => grid.appendChild(c));

      // Filter
      let visibleCount = 0;
      cards.forEach(c => {
        const tags = c.dataset.competencies.split(' ');
        const show = activeFilters.size === 0 || tags.some(t => activeFilters.has(t));
        c.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });
      emptyMsg.classList.toggle('hidden', visibleCount > 0);
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const f = btn.dataset.filter;
        if (f === 'all') {
          activeFilters.clear();
        } else {
          if (activeFilters.has(f)) {
            activeFilters.delete(f);
          } else {
            activeFilters.add(f);
          }
        }
        // Update data-active on all filter buttons
        filterBtns.forEach(b => {
          const bf = b.dataset.filter;
          if (bf === 'all') {
            b.dataset.active = activeFilters.size === 0 ? 'true' : 'false';
          } else {
            b.dataset.active = activeFilters.has(bf) ? 'true' : 'false';
          }
        });
        render();
      });
    });

    sortBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        activeSort = btn.dataset.sort;
        sortBtns.forEach(b => b.dataset.active = b === btn ? 'true' : 'false');
        render();
      });
    });
  })();
</script>
