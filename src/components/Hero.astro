---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const prefix = lang === 'en' ? '' : '/hu';
---

<section class="relative overflow-hidden">
  <!-- Soft warm backdrop blobs for the claymorphism feel -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -top-32 -left-24 w-[28rem] h-[28rem] rounded-full bg-amber/20 blur-3xl"></div>
    <div class="absolute top-40 -right-32 w-[32rem] h-[32rem] rounded-full bg-forest/10 blur-3xl"></div>
  </div>

  <div class="max-w-5xl mx-auto px-6 md:px-8 pt-20 md:pt-28 pb-20 md:pb-28">
    <p class="font-mono text-[11px] uppercase tracking-widest text-forest/70 mb-8">
      {t('hero.eyebrow')}
    </p>

    <h1 class="font-display font-semibold text-ink text-[2.5rem] sm:text-5xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tightest max-w-4xl">
      {t('hero.headline')}
    </h1>

    <p class="mt-8 max-w-2xl text-lg md:text-xl leading-relaxed text-muted">
      {t('hero.sub')}
    </p>

    <div class="mt-10 flex flex-wrap gap-3">
      <a
        href={`${prefix}/#work`}
        class="inline-flex items-center rounded-full bg-forest text-paper px-6 py-3 text-sm font-medium shadow-sm hover:bg-forest-dark transition-colors"
      >
        {t('hero.cta.work')}
      </a>
      <a
        href={`${prefix}/#contact`}
        class="inline-flex items-center rounded-full border border-ink/15 text-ink px-6 py-3 text-sm font-medium hover:border-forest hover:text-forest transition-colors"
      >
        {t('hero.cta.contact')}
      </a>
    </div>
  </div>
</section>
