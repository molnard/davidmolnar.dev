---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="bg-paper border-t border-ink/10">
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-3 text-xs font-mono text-muted/70">
    <span>© {year} David Molnar</span>
    <span>
      {t('footer.built')}{' '}
      <a
        href="https://github.com/molnard/davidmolnar.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="text-forest hover:text-amber-dark underline-offset-2 hover:underline"
      >
        GitHub
      </a>
    </span>
  </div>
</footer>
