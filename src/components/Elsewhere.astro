---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
  { label: 'GitHub',         href: 'https://github.com/molnard' },
  { label: 'LinkedIn',       href: 'https://www.linkedin.com/in/molnardavid84/' },
  { label: 'GingerPrivacy',  href: 'https://github.com/GingerPrivacy/' },
  { label: 'CodeLizardDev',  href: 'https://github.com/CodeLizardDev' },
  { label: 'MakerWorld',     href: 'https://makerworld.com/hu/@lizardFactory' },
];
---

<section id="elsewhere" class="border-t border-ink/10">
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-20 md:py-28">
    <h2 class="font-serif text-3xl md:text-4xl tracking-tight mb-10">
      {t('elsewhere.title')}
    </h2>
    <ul class="grid md:grid-cols-2 gap-x-8">
      {links.map(l => {
        const host = new URL(l.href).host.replace(/^www\./, '');
        return (
          <li>
            <a
              href={l.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 py-3 border-b border-ink/10 hover:border-accent/40 hover:text-accent transition-colors"
            >
              <span class="font-serif text-lg">{l.label}</span>
              <span class="font-mono text-[11px] opacity-40 ml-auto">{host}</span>
              <span class="font-mono text-xs opacity-40">↗</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</section>
