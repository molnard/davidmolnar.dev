---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="about" class="border-t border-ink/10">
  <div class="max-w-3xl mx-auto px-6 md:px-8 py-20 md:py-28">
    <h2 class="font-serif text-3xl md:text-4xl tracking-tight mb-10">
      {t('about.title')}
    </h2>
    <p class="text-lg md:text-xl leading-relaxed opacity-85">
      {t('about.body')}
    </p>
  </div>
</section>
