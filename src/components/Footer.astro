---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="bg-paper border-t border-ink/10">
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-xs font-mono text-muted/70">

    <!-- Left: copyright + legal -->
    <div class="flex flex-col gap-1">
      <span>© {year} David Molnar</span>
      <span>{t('footer.legal')}</span>
    </div>

    <!-- Center: Bitcoin accepted -->
    <!-- TODO: replace href with merchant directory listing URL when ready -->
    <a
      href="https://btcmap.org"
      target="_blank"
      rel="noopener noreferrer"
      title={t('footer.bitcoin')}
      class="opacity-90 hover:opacity-100 transition-opacity"
    >
      <img
        src="/images/bitcoin-accepted-here.png"
        alt="Bitcoin Accepted Here"
        width="1680"
        height="485"
        class="h-10 w-auto"
      />
    </a>

    <!-- Right: source -->
    <span>
      {t('footer.built')}{' '}
      <a
        href="https://github.com/molnard/davidmolnar.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="text-forest hover:text-amber-dark underline-offset-2 hover:underline"
      >
        GitHub
      </a>
    </span>

  </div>
</footer>
