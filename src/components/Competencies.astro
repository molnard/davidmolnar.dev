---
import { useTranslations, type Lang } from '../i18n/utils';
import fs from 'node:fs';
import path from 'node:path';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

// Anything in /public is served verbatim — at build time we check which competency images exist.
const competenciesDir = path.resolve('public/images/competencies');
const exts = ['webp', 'jpg', 'jpeg', 'png'];

function findImage(slug: string): string | null {
  for (const ext of exts) {
    const file = path.join(competenciesDir, `${slug}.${ext}`);
    if (fs.existsSync(file)) {
      return `/images/competencies/${slug}.${ext}`;
    }
  }
  return null;
}

interface Competency {
  id: string;
  slug: string;
  tag: string;
  title: string;
  short: string;
  alt: string;
  fallback: string;
  image: string | null;
  hero?: boolean;
}

const items: Competency[] = [
  { id: 'c-bitcoin',   slug: 'bitcoin',   tag: t('comp.bitcoin.tag'),   title: t('comp.bitcoin.title'),   short: t('comp.bitcoin.short'),   alt: t('comp.bitcoin.alt'),   fallback: 'bg-c-btc', image: findImage('bitcoin'),   hero: true },
  { id: 'c-software',  slug: 'software',  tag: t('comp.software.tag'),  title: t('comp.software.title'),  short: t('comp.software.short'),  alt: t('comp.software.alt'),  fallback: 'bg-c-sw',  image: findImage('software') },
  { id: 'c-firmware',  slug: 'firmware',  tag: t('comp.firmware.tag'),  title: t('comp.firmware.title'),  short: t('comp.firmware.short'),  alt: t('comp.firmware.alt'),  fallback: 'bg-c-fw',  image: findImage('firmware') },
  { id: 'c-smarthome', slug: 'smarthome', tag: t('comp.smarthome.tag'), title: t('comp.smarthome.title'), short: t('comp.smarthome.short'), alt: t('comp.smarthome.alt'), fallback: 'bg-c-sh',  image: findImage('smarthome') },
  { id: 'c-print',     slug: 'print',     tag: t('comp.print.tag'),     title: t('comp.print.title'),     short: t('comp.print.short'),     alt: t('comp.print.alt'),     fallback: 'bg-c-3d',  image: findImage('print') },
];
---

<section id="competencies" class="bg-[#0F1A14]">
  <div class="max-w-6xl mx-auto px-6 md:px-8 py-24 md:py-32">
    <h2 class="font-display font-semibold text-3xl md:text-4xl tracking-tight text-paper mb-14">
      {t('comp.title')}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {items.map(c => (
        <a
          href={`#${c.id}`}
          class={`group relative block rounded-3xl overflow-hidden ${c.hero ? 'md:col-span-2 aspect-[16/10] md:aspect-[21/8]' : 'aspect-[4/3]'}`}
        >
          {c.image
            ? <img
                src={c.image}
                alt={c.alt}
                loading={c.hero ? 'eager' : 'lazy'}
                {...(c.hero ? { fetchpriority: 'high' } : {})}
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.06]"
              />
            : <div class={`absolute inset-0 ${c.fallback} transition-transform duration-700 ease-out group-hover:scale-[1.06]`} role="img" aria-label={c.alt}></div>
          }
          <div class="absolute inset-0 bg-gradient-to-t from-[#0F1A14]/85 via-[#0F1A14]/30 to-transparent"></div>

          <span class="absolute top-6 right-6 md:top-7 md:right-7 w-11 h-11 rounded-full bg-paper/15 backdrop-blur-md flex items-center justify-center text-paper text-lg transition-all duration-300 group-hover:bg-amber group-hover:text-forest-dark group-hover:-rotate-45" aria-hidden="true">↓</span>

          <div class="relative z-10 h-full p-7 md:p-8 flex flex-col justify-end">
            <span class="font-mono text-[10px] uppercase tracking-widest text-amber mb-3">{c.tag}</span>
            <h3 class={`font-display font-bold tracking-tight text-paper mb-2 ${c.hero ? 'text-3xl md:text-5xl' : 'text-2xl md:text-3xl'}`}>{c.title}</h3>
            <p class="text-paper/85 text-sm md:text-[15px] leading-relaxed max-w-2xl">{c.short}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .bg-c-btc {
    background:
      radial-gradient(circle at 30% 70%, #F7931A 0%, transparent 45%),
      radial-gradient(circle at 70% 30%, #4A1F00 0%, transparent 50%),
      linear-gradient(135deg, #2A1100 0%, #5C2D00 100%);
  }
  .bg-c-sw {
    background:
      radial-gradient(ellipse at 80% 20%, rgba(232,163,60,0.18) 0%, transparent 50%),
      linear-gradient(135deg, #1F352B 0%, #0A1F15 100%);
  }
  .bg-c-fw {
    background:
      radial-gradient(circle at 50% 50%, rgba(232,163,60,0.12) 0%, transparent 60%),
      linear-gradient(135deg, #0F2A1F 0%, #1F4A35 100%);
  }
  .bg-c-sh {
    background:
      linear-gradient(135deg, #1A2E25 0%, #3F5F52 50%, #B8801F 100%);
  }
  .bg-c-3d {
    background:
      conic-gradient(from 45deg at 50% 50%, #1F352B 0%, #2F4A3F 25%, #1F352B 50%, #2F4A3F 75%, #1F352B 100%);
  }
</style>
