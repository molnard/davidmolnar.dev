---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
  { label: 'GitHub',        href: 'https://github.com/molnard' },
  { label: 'LinkedIn',      href: 'https://www.linkedin.com/in/molnardavid84/' },
  { label: 'Algora',        href: 'https://algora.io/molnard' },
  { label: 'Wasabi Wallet', href: 'https://github.com/WalletWasabi/WalletWasabi' },
  { label: 'GingerPrivacy', href: 'https://github.com/GingerPrivacy/' },
];
---

<section id="elsewhere" class="bg-cream border-t border-ink/5">
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-20 md:py-28">
    <h2 class="font-display font-semibold text-3xl md:text-4xl tracking-tight text-ink mb-10">
      {t('elsewhere.title')}
    </h2>
    <ul class="grid md:grid-cols-2 gap-x-8">
      {links.map(l => {
        const host = new URL(l.href).host.replace(/^www\./, '');
        return (
          <li>
            <a
              href={l.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-3 py-4 border-b border-ink/10 hover:border-forest transition-colors"
            >
              <span class="font-display font-medium text-lg text-ink group-hover:text-forest transition-colors">{l.label}</span>
              <span class="font-mono text-[11px] text-muted/70 ml-auto">{host}</span>
              <span class="font-mono text-xs text-muted/70 group-hover:text-amber-dark transition-colors">↗</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</section>
