---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from './ProjectCard.astro';
import { useTranslations, type Lang } from '../i18n/utils';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

type CompetencyKey = 'bitcoin' | 'software' | 'firmware' | 'smarthome' | '3d-printing';

interface Props {
  lang: Lang;
  competency: CompetencyKey;
  title: string;
  description: string;
  detail: string;
  tag: string;
  image?: string;
  fallbackClass: string;
  altHref: string;
}

const { lang, competency, title, description, detail, tag, image, fallbackClass, altHref } = Astro.props;
const t = useTranslations(lang);

const allProjects = await getCollection('projects');
const projects = allProjects.filter(
  (p: CollectionEntry<'projects'>) => p.data.lang === lang && !p.data.draft && p.data.competencies.includes(competency)
);

const projectHref = (p: CollectionEntry<'projects'>) =>
  lang === 'hu' ? `/hu/projects/${p.data.projectId}/` : `/projects/${p.data.projectId}/`;
---

<BaseLayout {title} {description} {altHref}>
  <!-- Hero -->
  <div class={`relative w-full aspect-[16/7] md:aspect-[21/6] overflow-hidden ${!image ? fallbackClass : ''}`}>
    {image && (
      <img
        src={image}
        alt={title}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover"
      />
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-[#0F1A14]/80 via-[#0F1A14]/30 to-transparent"></div>
    <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-14 max-w-6xl mx-auto w-full">
      <a href={lang === 'hu' ? '/hu/' : '/'} class="font-mono text-[11px] uppercase tracking-widest text-paper/60 hover:text-paper transition-colors mb-4 inline-block">{t('comp.page.back')}</a>
      <span class="font-mono text-[10px] uppercase tracking-widest text-amber mb-3">{tag}</span>
      <h1 class="font-display font-bold text-3xl md:text-5xl tracking-tight text-paper">{title}</h1>
    </div>
  </div>

  <!-- Detail -->
  <section class="bg-paper">
    <div class="max-w-3xl mx-auto px-6 md:px-8 py-16 md:py-24">
      <slot name="detail">
        <p class="text-lg md:text-xl leading-relaxed text-muted">{detail}</p>
      </slot>
    </div>
  </section>

  <!-- Extra slot (optional per-page content) -->
  <slot name="extra" />

  <!-- Projects -->
  {projects.length > 0 && (
    <section class="bg-[#0F1A14]">
      <div class="max-w-6xl mx-auto px-6 md:px-8 py-16 md:py-24">
        <h2 class="font-display font-semibold text-2xl md:text-3xl tracking-tight text-paper mb-10">
          {t('comp.page.projects')}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {projects.map((p: CollectionEntry<'projects'>) => (
            <ProjectCard
              title={p.data.title}
              shortDesc={p.data.shortDesc}
              image={p.data.image}
              tags={p.data.tags}
              year={p.data.year}
              href={projectHref(p)}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
