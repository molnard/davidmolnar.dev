---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const projects = [
  {
    title: 'GingerPrivacy',
    role: t('work.role.lead'),
    desc: t('work.desc.ginger'),
    href: 'https://github.com/GingerPrivacy/',
  },
  {
    title: 'CodeLizardDev',
    role: t('work.role.personal'),
    desc: t('work.desc.codelizard'),
    href: 'https://github.com/CodeLizardDev',
  },
  {
    title: 'lizardFactory',
    role: t('work.role.designer'),
    desc: t('work.desc.lizardfactory'),
    href: 'https://makerworld.com/hu/@lizardFactory',
  },
];
---

<section id="work" class="border-t border-ink/10">
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-20 md:py-28">
    <h2 class="font-serif text-3xl md:text-4xl tracking-tight mb-14">
      {t('work.title')}
    </h2>
    <div>
      {projects.map(p => (
        <a
          href={p.href}
          target="_blank"
          rel="noopener noreferrer"
          class="block border-t border-ink/10 py-6 group hover:bg-ink/[0.02] transition-colors"
        >
          <div class="flex items-baseline justify-between gap-6 flex-wrap">
            <div class="flex-1 min-w-0">
              <h3 class="font-serif text-2xl md:text-3xl tracking-tight group-hover:text-accent transition-colors">
                {p.title}
              </h3>
              <p class="mt-2 opacity-70 leading-relaxed">{p.desc}</p>
            </div>
            <span class="font-mono text-[11px] opacity-50 uppercase tracking-widest whitespace-nowrap">
              {p.role}
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
