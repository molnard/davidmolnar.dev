---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const pillars = [
  { num: '01', title: t('pillars.software.title'),  body: t('pillars.software.body') },
  { num: '02', title: t('pillars.embedded.title'),  body: t('pillars.embedded.body') },
  { num: '03', title: t('pillars.oss.title'),       body: t('pillars.oss.body') },
  { num: '04', title: t('pillars.print.title'),     body: t('pillars.print.body') },
  { num: '05', title: t('pillars.smarthome.title'), body: t('pillars.smarthome.body') },
];
---

<section id="pillars" class="bg-paper">
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-20 md:py-28">
    <h2 class="font-display font-semibold text-3xl md:text-4xl tracking-tight text-ink mb-14">
      {t('pillars.title')}
    </h2>
    <div class="grid md:grid-cols-2 gap-6">
      {pillars.map(({ num, title, body }) => (
        <article class="rounded-3xl bg-cream p-8 md:p-10 border border-ink/5">
          <span class="font-mono text-[11px] uppercase tracking-widest text-amber-dark">{num}</span>
          <h3 class="font-display font-semibold text-2xl md:text-[26px] mt-3 mb-3 tracking-tight text-ink">
            {title}
          </h3>
          <p class="text-muted leading-relaxed">{body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
