---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  altLang: Lang;
  altHref: string;
}

const { lang, altLang, altHref } = Astro.props;
const t = useTranslations(lang);
const prefix = lang === 'en' ? '' : '/hu';
const home = lang === 'en' ? '/' : '/hu/';
---

<header class="sticky top-0 z-50 bg-paper/85 backdrop-blur-md border-b border-ink/5">
  <nav class="max-w-5xl mx-auto px-6 md:px-8 py-4 flex items-center justify-between">
    <a
      href={home}
      class="font-display font-semibold text-lg tracking-tight text-ink hover:text-forest transition-colors"
    >
      <span>David Molnar</span>
    </a>
    <div class="flex items-center gap-5 md:gap-7 text-sm">
      <a href={`${prefix}/#work`} class="hidden sm:inline text-ink/80 hover:text-forest transition-colors">{t('nav.work')}</a>
      <a href={`${prefix}/#about`} class="hidden sm:inline text-ink/80 hover:text-forest transition-colors">{t('nav.about')}</a>
      <a href={`${prefix}/#contact`} class="hidden sm:inline text-ink/80 hover:text-forest transition-colors">{t('nav.contact')}</a>
      <div class="font-mono text-[11px] uppercase tracking-widest flex items-center gap-1.5 ml-2">
        {lang === 'en' ? (
          <span class="text-forest font-semibold">EN</span>
        ) : (
          <a href="/" class="text-ink/40 hover:text-forest transition-colors">EN</a>
        )}
        <span class="text-ink/20">/</span>
        {lang === 'hu' ? (
          <span class="text-forest font-semibold">HU</span>
        ) : (
          <a href="/hu/" class="text-ink/40 hover:text-forest transition-colors">HU</a>
        )}
      </div>
    </div>
  </nav>
</header>
