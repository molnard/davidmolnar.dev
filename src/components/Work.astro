---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

interface Project {
  title: string;
  role: string;
  desc: string;
  initial: string;
  href: string | null;
  logo?: string;
}

const projects: Project[] = [
  {
    title:   t('work.wasabi.title'),
    role:    t('work.wasabi.role'),
    desc:    t('work.wasabi.desc'),
    initial: 'W',
    href:    'https://wasabiwallet.io/',
  },
  {
    title:   t('work.ginger.title'),
    role:    t('work.ginger.role'),
    desc:    t('work.ginger.desc'),
    initial: 'G',
    href:    'https://gingerwallet.io/',
  },
  {
    title:   t('work.fetaphon.title'),
    role:    t('work.fetaphon.role'),
    desc:    t('work.fetaphon.desc'),
    initial: 'F',
    href:    'https://www.stylemagazin.hu/kiemelt-hir/Felugyeld-otthonrol-is-biztonsaggal-magzatod-fejlodeset/10574/stylenews/interjuk/',
  },
  {
    title:   t('work.tesco.title'),
    role:    t('work.tesco.role'),
    desc:    t('work.tesco.desc'),
    initial: 'T',
    href:    null,
  },
  {
    title:   t('work.agis.title'),
    role:    t('work.agis.role'),
    desc:    t('work.agis.desc'),
    initial: 'A',
    href:    null,
  },
];

const tileClasses =
  'group relative block rounded-3xl bg-forest-dark border border-paper/10 overflow-hidden aspect-square transition-colors hover:border-amber/40';
---

<section id="work" class="bg-forest text-paper">
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-24 md:py-32">
    <h2 class="font-display font-semibold text-3xl md:text-4xl tracking-tight mb-14">
      {t('work.title')}
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map(p => (p.href ? (
        <a href={p.href} target="_blank" rel="noopener noreferrer" class={tileClasses}>
          <div class="absolute inset-0 flex flex-col justify-between p-6 md:p-7 transition-opacity duration-300 group-hover:opacity-0">
            <div class="flex items-start justify-between gap-3">
              <span class="font-mono text-[10px] uppercase tracking-widest text-amber">{p.role}</span>
              <span class="font-mono text-xs text-paper/40">↗</span>
            </div>
            <div>
              <div class="font-display font-bold leading-none text-[5.5rem] md:text-[6.5rem] text-amber/80 mb-2 -ml-1">{p.initial}</div>
              <h3 class="font-display font-semibold text-xl md:text-2xl tracking-tight text-paper">{p.title}</h3>
            </div>
          </div>
          <div class="absolute inset-0 flex flex-col justify-between p-6 md:p-7 bg-forest opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <span class="font-mono text-[10px] uppercase tracking-widest text-amber">{p.role}</span>
            <div>
              <h3 class="font-display font-semibold text-lg md:text-xl tracking-tight text-amber mb-3">{p.title}</h3>
              <p class="text-paper/90 text-sm md:text-[15px] leading-relaxed">{p.desc}</p>
            </div>
          </div>
        </a>
      ) : (
        <div class={tileClasses}>
          <div class="absolute inset-0 flex flex-col justify-between p-6 md:p-7 transition-opacity duration-300 group-hover:opacity-0">
            <span class="font-mono text-[10px] uppercase tracking-widest text-amber">{p.role}</span>
            <div>
              <div class="font-display font-bold leading-none text-[5.5rem] md:text-[6.5rem] text-amber/80 mb-2 -ml-1">{p.initial}</div>
              <h3 class="font-display font-semibold text-xl md:text-2xl tracking-tight text-paper">{p.title}</h3>
            </div>
          </div>
          <div class="absolute inset-0 flex flex-col justify-between p-6 md:p-7 bg-forest opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <span class="font-mono text-[10px] uppercase tracking-widest text-amber">{p.role}</span>
            <div>
              <h3 class="font-display font-semibold text-lg md:text-xl tracking-tight text-amber mb-3">{p.title}</h3>
              <p class="text-paper/90 text-sm md:text-[15px] leading-relaxed">{p.desc}</p>
            </div>
          </div>
        </div>
      )))}
    </div>

    <div class="md:hidden mt-8 space-y-3 text-sm text-paper/70">
      {projects.map(p => (
        <p><span class="text-amber font-semibold">{p.title}</span> — {p.desc}</p>
      ))}
    </div>
  </div>
</section>
