---
interface Props {
  title: string;
  shortDesc: string;
  image?: string;
  tags: string[];
  href: string;
  year?: number;
}

const { title, shortDesc, image, tags, href, year } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col rounded-2xl overflow-hidden border border-ink/10 bg-paper hover:border-forest/40 transition-colors"
>
  {image && (
    <div class="aspect-[16/9] overflow-hidden bg-[#0F1A14]">
      <img
        src={image}
        alt={title}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
      />
    </div>
  )}
  {!image && (
    <div class="aspect-[16/9] bg-gradient-to-br from-[#1F352B] to-[#0F1A14]"></div>
  )}

  <div class="flex flex-col flex-1 p-5">
    <div class="flex items-start justify-between gap-3 mb-2">
      <h3 class="font-display font-semibold text-lg text-ink group-hover:text-forest transition-colors">{title}</h3>
      {year && <span class="font-mono text-[11px] text-muted shrink-0 mt-1">{year}</span>}
    </div>
    <p class="text-sm text-muted leading-relaxed mb-4 flex-1">{shortDesc}</p>
    <div class="flex flex-wrap gap-1.5">
      {tags.slice(0, 4).map(tag => (
        <span class="font-mono text-[10px] uppercase tracking-wide px-2 py-0.5 rounded-full bg-forest/10 text-forest-dark">{tag}</span>
      ))}
    </div>
  </div>
</a>
