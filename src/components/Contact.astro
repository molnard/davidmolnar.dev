---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="border-t border-ink/10">
  <div class="max-w-3xl mx-auto px-6 md:px-8 py-20 md:py-28">
    <h2 class="font-serif text-3xl md:text-4xl tracking-tight mb-8">
      {t('contact.title')}
    </h2>
    <p class="text-lg leading-relaxed opacity-80 mb-10">
      {t('contact.body')}
    </p>
    <a
      href="mailto:hello@davidmolnar.dev"
      class="inline-block font-serif text-2xl md:text-4xl tracking-tight hover:text-accent transition-colors border-b border-accent/30 hover:border-accent pb-1"
    >
      hello@davidmolnar.dev
    </a>
  </div>
</section>
