---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const pillars = [
  { num: '01', title: t('pillars.software.title'), body: t('pillars.software.body') },
  { num: '02', title: t('pillars.oss.title'),      body: t('pillars.oss.body') },
  { num: '03', title: t('pillars.maker.title'),    body: t('pillars.maker.body') },
  { num: '04', title: t('pillars.practice.title'), body: t('pillars.practice.body') },
];
---

<section id="pillars" class="border-t border-ink/10">
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-20 md:py-28">
    <h2 class="font-serif text-3xl md:text-4xl tracking-tight mb-14">
      {t('pillars.title')}
    </h2>
    <div class="grid md:grid-cols-2 gap-x-12 gap-y-14">
      {pillars.map(({ num, title, body }) => (
        <article>
          <span class="font-mono text-xs opacity-40 tracking-widest">{num}</span>
          <h3 class="font-serif text-2xl md:text-3xl mt-2 mb-3 tracking-tight">{title}</h3>
          <p class="opacity-75 leading-relaxed">{body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
