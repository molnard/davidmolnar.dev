---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

interface Partner {
  name: string;
  href?: string;
  logo?: string;
}

const partners: Partner[] = [
  { name: 'Wasabi Wallet',  href: 'https://wasabiwallet.io/' },
  { name: 'Ginger Wallet',  href: 'https://gingerwallet.io/' },
  { name: 'Fetaphon',       href: 'https://www.stylemagazin.hu/kiemelt-hir/Felugyeld-otthonrol-is-biztonsaggal-magzatod-fejlodeset/10574/stylenews/interjuk/' },
  { name: 'TESCO' },
  { name: 'AGIS' },
  { name: 'ADT' },
  { name: 'Smartopert' },
];
---

<section id="partners" class="bg-paper border-t border-ink/10">
  <div class="max-w-5xl mx-auto px-6 md:px-8 py-16 md:py-20">
    <p class="font-mono text-[11px] uppercase tracking-widest text-amber-dark mb-6">
      {t('partners.title')}
    </p>

    <ul class="flex flex-wrap items-center gap-x-8 gap-y-4">
      {partners.map(p => (p.href ? (
        <li>
          <a href={p.href} target="_blank" rel="noopener noreferrer" class="font-display font-semibold text-lg md:text-xl tracking-tight text-ink/65 hover:text-forest transition-colors">{p.name}</a>
        </li>
      ) : (
        <li>
          <span class="font-display font-semibold text-lg md:text-xl tracking-tight text-ink/65">{p.name}</span>
        </li>
      )))}
    </ul>
  </div>
</section>
